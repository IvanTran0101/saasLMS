# nonsecret.env.j2
# Production-ready non-secret environment template for saasLMS.
# This file intentionally excludes secrets such as connection strings, client secrets,
# AbpLicenseCode, passphrases, access keys, and passwords.
#
# Expected Ansible variables:
# - public_app_domain
# - public_api_domain
# - public_auth_domain
# - an infra host in the `infra` inventory group with either:
#   - infra_private_ip, or
#   - ansible_host as a fallback

{% set infra_host_name = groups['infra'][0] %}
{% set infra_internal_host = hostvars[infra_host_name]['infra_private_ip'] | default(hostvars[infra_host_name]['ansible_host']) %}
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:80
ASPNETCORE_FORWARDEDHEADERS_ENABLED=true
AllowedHosts=*
App__DisablePII=false

# ===== Public domains =====
App__CorsOrigins=https://{{ public_app_domain }},https://{{ public_api_domain }},https://{{ public_auth_domain }}
App__RedirectAllowedUrls=https://{{ public_app_domain }},https://{{ public_api_domain }},https://{{ public_auth_domain }},https://{{ public_app_domain }}/authentication/login-callback,https://{{ public_app_domain }}/authentication/logout-callback,https://{{ public_app_domain }}/signin-oidc,https://{{ public_app_domain }}/signout-callback-oidc,https://{{ public_api_domain }}/signin-oidc,https://{{ public_api_domain }}/signout-callback-oidc

# ===== Auth Server =====
App__SelfUrl=https://{{ public_auth_domain }}
AuthServer__Authority=https://{{ public_auth_domain }}
AuthServer__MetadataAddress=https://{{ public_auth_domain }}
AuthServer__RequireHttpsMetadata=true
AuthServer__SwaggerClientId=WebGateway_Swagger
AuthServer__ClientId=Blazor
AuthServer__ResponseType=code
IdentityClients__Default__Authority=https://{{ public_auth_domain }}
IdentityClients__Default__RequireHttps=true
IdentityClients__AbpMvcClient__Authority=https://{{ public_auth_domain }}
IdentityClients__AbpMvcClient__RequireHttps=true

# ===== OpenIddict application root URLs =====
OpenIddict__Applications__WebGateway__RootUrl=https://{{ public_api_domain }}
OpenIddict__Applications__PublicWebGateway__RootUrl=https://{{ public_api_domain }}
OpenIddict__Applications__Web__RootUrl=https://{{ public_api_domain }}
OpenIddict__Applications__Blazor__RootUrl=https://{{ public_app_domain }}
OpenIddict__Applications__BlazorServer__RootUrl=https://{{ public_app_domain }}
OpenIddict__Applications__BlazorWebApp__RootUrl=https://{{ public_app_domain }}
OpenIddict__Applications__PublicWeb__RootUrl=https://{{ public_app_domain }}
OpenIddict__Applications__Angular__RootUrl=https://{{ public_app_domain }}

# ===== OpenIddict resource root URLs =====
OpenIddict__Resources__AccountService__RootUrl=https://{{ public_auth_domain }}
OpenIddict__Resources__IdentityService__RootUrl=https://{{ public_api_domain }}
OpenIddict__Resources__AdministrationService__RootUrl=https://{{ public_api_domain }}
OpenIddict__Resources__SaasService__RootUrl=https://{{ public_api_domain }}
OpenIddict__Resources__ProductService__RootUrl=https://{{ public_api_domain }}
OpenIddict__Resources__CourseCatalogService__RootUrl=https://{{ public_api_domain }}
OpenIddict__Resources__EnrollmentService__RootUrl=https://{{ public_api_domain }}
OpenIddict__Resources__LearningProgressService__RootUrl=https://{{ public_api_domain }}
OpenIddict__Resources__AssessmentService__RootUrl=https://{{ public_api_domain }}
OpenIddict__Resources__ReportingService__RootUrl=https://{{ public_api_domain }}

# ===== Shared infra endpoints =====
ElasticSearch__Url=http://{{ infra_internal_host }}:9200
RabbitMQ__Connections__Default__HostName={{ infra_internal_host }}
RabbitMQ__Connections__Default__Port=5672
RabbitMQ__EventBus__ExchangeName=saasLMS
Redis__Configuration={{ infra_internal_host }}:6379

# ===== App / Blazor =====
RemoteServices__AssessmentService__BaseUrl=https://{{ public_api_domain }}
RemoteServices__Default__BaseUrl=https://{{ public_api_domain }}
RemoteServices__EnrollmentService__BaseUrl=https://{{ public_api_domain }}
RemoteServices__ReportingService__BaseUrl=https://{{ public_api_domain }}
RemoteServices__course-catalog__BaseUrl=https://{{ public_api_domain }}

# ===== Service self URLs =====
# These values represent the public-facing URLs used by services behind the gateway.
# Keep them on the API domain unless a service is deliberately exposed on a dedicated domain.
AdministrationService__App__SelfUrl=https://{{ public_api_domain }}
AssessmentService__App__SelfUrl=https://{{ public_api_domain }}
CourseCatalogService__App__SelfUrl=https://{{ public_api_domain }}
EnrollmentService__App__SelfUrl=https://{{ public_api_domain }}
IdentityService__App__SelfUrl=https://{{ public_api_domain }}
LearningProgressService__App__SelfUrl=https://{{ public_api_domain }}
NotificationService__App__SelfUrl=https://{{ public_api_domain }}
ProductService__App__SelfUrl=https://{{ public_api_domain }}
ReportingService__App__SelfUrl=https://{{ public_api_domain }}
SaasService__App__SelfUrl=https://{{ public_api_domain }}

# ===== Event bus client names =====
RabbitMQ__EventBus__ClientName=AuthServer
AdministrationService__RabbitMQ__EventBus__ClientName=saasLMS_AdministrationService
AssessmentService__RabbitMQ__EventBus__ClientName=saasLMS_AssessmentService
CourseCatalogService__RabbitMQ__EventBus__ClientName=saasLMS_CourseCatalogService
