# ===== Service-specific remote services =====
AdministrationService__RemoteServices__AbpIdentity__BaseUrl=https://{{ public_api_domain }}/
AdministrationService__RemoteServices__AbpIdentity__UseCurrentAccessToken=false

AssessmentService__RemoteServices__course-catalog__BaseUrl=https://{{ public_api_domain }}
AssessmentService__RemoteServices__course-catalog__UseCurrentAccessToken=true

CourseCatalogService__RemoteServices__EnrollmentService__BaseUrl=https://{{ public_api_domain }}
CourseCatalogService__RemoteServices__EnrollmentService__IdentityClient=Default
CourseCatalogService__RemoteServices__EnrollmentService__UseCurrentAccessToken=false

EnrollmentService__RemoteServices__course-catalog__BaseUrl=https://{{ public_api_domain }}
EnrollmentService__RemoteServices__course-catalog__IdentityClient=Default
EnrollmentService__RemoteServices__course-catalog__UseCurrentAccessToken=false

LearningProgressService__RemoteServices__EnrollmentService__BaseUrl=https://{{ public_api_domain }}
LearningProgressService__RemoteServices__EnrollmentService__IdentityClient=Default
LearningProgressService__RemoteServices__EnrollmentService__UseCurrentAccessToken=false

# ===== DbMigrator =====
DbMigrator__ElasticSearch__Url=http://{{ infra_internal_host }}:9200
DbMigrator__Redis__Configuration={{ infra_internal_host }}:6379

