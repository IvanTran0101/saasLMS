@page "/student/courses/{CourseId:guid}"
@inherits AbpComponentBase

@using System.Linq
@using saasLMS.CourseCatalogService.Courses

<PageTitle>@(_course?.Title ?? "Course Preview")</PageTitle>

<style>
    .scp-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.85rem;
        font-weight: 500;
        color: #6c757d;
        text-decoration: none;
        margin-bottom: 1.25rem;
        border: none;
        background: none;
        padding: 0;
        cursor: pointer;
        transition: color 0.15s;
    }

    .scp-back-btn:hover { color: #1a73e8; }

    /* ── Hero ── */
    .scp-hero {
        background: linear-gradient(135deg, #0f2744 0%, #1a3a5c 60%, #1e4976 100%);
        border-radius: 16px;
        padding: 3rem 2.5rem;
        color: #fff;
        position: relative;
        overflow: hidden;
        margin-bottom: 2rem;
    }

    .scp-hero__tag {
        display: inline-block;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        padding: 3px 10px;
        border-radius: 5px;
        background: rgba(255,255,255,0.15);
        color: #fff;
        margin-bottom: 1rem;
    }

    .scp-hero__title {
        font-size: 2.2rem;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 1rem;
        max-width: 700px;
    }

    .scp-hero__desc {
        font-size: 1rem;
        opacity: 0.8;
        max-width: 620px;
        margin-bottom: 1.75rem;
        line-height: 1.6;
    }

    .scp-hero__enroll-btn {
        background: #fff;
        color: #0f2744;
        border: none;
        border-radius: 10px;
        padding: 0.7rem 2rem;
        font-size: 0.92rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.15s, transform 0.15s;
        text-decoration: none;
    }

    .scp-hero__enroll-btn:hover {
        background: #e8f0fe;
        transform: translateY(-1px);
    }

    .scp-hero__enroll-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

    .scp-hero__deco {
        position: absolute;
        right: 0;
        top: 0;
        bottom: 0;
        width: 260px;
        pointer-events: none;
        opacity: 0.07;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10rem;
    }

    /* ── Instructor card ── */
    .scp-instructor {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .scp-instructor__avatar {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1a73e8, #0f2744);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }

    .scp-instructor__label {
        font-size: 0.7rem;
        color: #8a93a2;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 0.15rem;
    }

    .scp-instructor__name {
        font-size: 1rem;
        font-weight: 700;
        color: #0d1117;
    }

    .scp-instructor__role {
        font-size: 0.8rem;
        color: #6c757d;
    }

    /* ── Stats row ── */
    .scp-stats {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 14px;
        padding: 1rem 1.5rem;
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .scp-stat-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        color: #495057;
    }

    .scp-stat-item__icon {
        color: #1a73e8;
        font-size: 0.9rem;
    }

    .scp-stat-item__value { font-weight: 600; }

    /* ── Section title ── */
    .scp-section-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: #0d1117;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #e9ecef;
    }

    /* ── Curriculum ── */
    .scp-chapter {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 12px;
        margin-bottom: 0.75rem;
        overflow: hidden;
    }

    .scp-chapter__header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.25rem;
    }

    .scp-chapter__left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .scp-chapter__num {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #e8f0fe;
        color: #1a73e8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.72rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .scp-chapter__title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #0d1117;
    }

    .scp-chapter__right {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .scp-chapter__lesson-count {
        font-size: 0.78rem;
        color: #8a93a2;
        white-space: nowrap;
    }

    .scp-chapter__lock {
        color: #ced4da;
        font-size: 0.85rem;
    }

    /* ── CTA footer ── */
    .scp-cta {
        background: linear-gradient(135deg, #0f2744 0%, #1a3a5c 100%);
        border-radius: 16px;
        padding: 3rem 2rem;
        text-align: center;
        color: #fff;
        margin-top: 2.5rem;
    }

    .scp-cta__title {
        font-size: 1.6rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

    .scp-cta__sub {
        opacity: 0.75;
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
    }

    .scp-cta__btn {
        background: #fff;
        color: #0f2744;
        border: none;
        border-radius: 10px;
        padding: 0.75rem 2.5rem;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.15s;
        text-decoration: none;
    }

    .scp-cta__btn:hover { background: #e8f0fe; }
    .scp-cta__btn:disabled { opacity: 0.6; cursor: not-allowed; }

    /* ── Skeleton ── */
    .scp-skel {
        border-radius: 16px;
        height: 280px;
        background: linear-gradient(90deg, #f0f2f5 25%, #e4e7eb 50%, #f0f2f5 75%);
        background-size: 200% 100%;
        animation: scp-shimmer 1.4s infinite;
        margin-bottom: 2rem;
    }

    @@keyframes scp-shimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }
</style>

<button class="scp-back-btn" @onclick="GoBack">
    <i class="fa fa-arrow-left"></i> Back to Dashboard
</button>

@if (_isLoading)
{
    <div class="scp-skel"></div>
    <div class="scp-skel" style="height:120px"></div>
}
else if (_course is null)
{
    <div class="text-center py-5 text-muted">
        <i class="fa fa-exclamation-circle fa-2x mb-3 d-block"></i>
        Course not found or not available.
    </div>
}
else
{
    @* ── Hero ── *@
    <div class="scp-hero">
        <span class="scp-hero__tag"><i class="fa fa-book me-1"></i>Course Preview</span>
        <h1 class="scp-hero__title">@_course.Title</h1>
        @if (!string.IsNullOrWhiteSpace(_course.Description))
        {
            <p class="scp-hero__desc">@_course.Description</p>
        }
        <button class="scp-hero__enroll-btn"
                @onclick="EnrollAsync"
                disabled="@(_enrolling || _isEnrolled)">
            @if (_enrolling)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            @(_isEnrolled ? "Already Enrolled" : "Enroll Now")
        </button>
        <div class="scp-hero__deco">
            <i class="fa fa-graduation-cap"></i>
        </div>
    </div>

    @* ── Instructor ── *@
    <div class="scp-instructor">
        <div class="scp-instructor__avatar">
            <i class="fa fa-user"></i>
        </div>
        <div>
            <div class="scp-instructor__label">Instructor</div>
            <div class="scp-instructor__name">@_instructorName</div>
            <div class="scp-instructor__role">Course Instructor</div>
        </div>
    </div>

    @* ── Stats ── *@
    <div class="scp-stats">
        <div class="scp-stat-item">
            <i class="fa fa-list-ul scp-stat-item__icon"></i>
            <span class="scp-stat-item__value">@_course.Chapters.Count</span>
            <span>Chapters</span>
        </div>
        <div class="scp-stat-item">
            <i class="fa fa-file-text-o scp-stat-item__icon"></i>
            <span class="scp-stat-item__value">@_totalLessons</span>
            <span>Lessons</span>
        </div>
        <div class="scp-stat-item">
            <i class="fa fa-signal scp-stat-item__icon"></i>
            <span class="scp-stat-item__value">All Levels</span>
        </div>
    </div>

    @* ── About ── *@
    @if (!string.IsNullOrWhiteSpace(_course.Description))
    {
        <h5 class="scp-section-title">About this Course</h5>
        <p class="text-muted mb-4" style="line-height:1.75; font-size:0.95rem;">@_course.Description</p>
    }

    @* ── Curriculum Preview ── *@
    <h5 class="scp-section-title">
        Curriculum Preview
        <span class="ms-2 text-muted" style="font-size:0.78rem; font-weight:400;">
            @_course.Chapters.Count modules &bull; @_totalLessons lessons
        </span>
    </h5>

    @foreach (var chapter in _course.Chapters.OrderBy(c => c.OrderNo))
    {
        <div class="scp-chapter">
            <div class="scp-chapter__header">
                <div class="scp-chapter__left">
                    <div class="scp-chapter__num">@chapter.OrderNo</div>
                    <span class="scp-chapter__title">@chapter.Title</span>
                </div>
                <div class="scp-chapter__right">
                    <span class="scp-chapter__lesson-count">
                        @chapter.Lessons.Count @(chapter.Lessons.Count == 1 ? "lesson" : "lessons")
                    </span>
                    <i class="fa fa-lock scp-chapter__lock"></i>
                </div>
            </div>
        </div>
    }

    @* ── CTA Footer ── *@
    <div class="scp-cta">
        <div class="scp-cta__title">Ready to start learning?</div>
        <div class="scp-cta__sub">Enroll now to unlock all lessons and track your progress.</div>
        <button class="scp-cta__btn"
                @onclick="EnrollAsync"
                disabled="@(_enrolling || _isEnrolled)">
            @if (_enrolling)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            @(_isEnrolled ? "Already Enrolled" : "Enroll Now")
        </button>
    </div>
}
