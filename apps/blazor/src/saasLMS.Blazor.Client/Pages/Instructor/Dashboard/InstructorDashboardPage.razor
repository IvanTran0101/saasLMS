@page "/instructor/dashboard"
@inherits AbpComponentBase

@using saasLMS.Blazor.Client.Components.Shared
@using saasLMS.CourseCatalogService.Courses

<PageTitle>Instructor Dashboard</PageTitle>

<CreateCourseModal @ref="_createCourseModal" OnCourseCreated="OnCourseCreated" />

<style>
    .idb-hero {
        background: linear-gradient(135deg, #4a1fa8 0%, #5741d8 60%, #7132f5 100%);
        border-radius: 12px;
        padding: 2.5rem 2rem;
        position: relative;
        overflow: hidden;
        color: #fff;
        margin-bottom: 1.5rem;
    }

    .idb-hero__title {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.4rem;
    }

    .idb-hero__subtitle {
        opacity: 0.72;
        margin-bottom: 1.25rem;
        font-size: 0.95rem;
    }

    .idb-hero__actions .btn-glass {
        background: rgba(255,255,255,0.14);
        border: 1px solid rgba(255,255,255,0.28);
        color: #fff;
        backdrop-filter: blur(4px);
        border-radius: 12px;
    }

    .idb-hero__actions .btn-glass:hover {
        background: rgba(255,255,255,0.24);
        color: #fff;
    }

    .idb-hero__deco {
        position: absolute;
        right: 2.5rem;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
    }

    .idb-hero__star {
        position: absolute;
        color: rgba(255,255,255,0.10);
    }

    .idb-hero__star--lg { font-size: 7rem; right: 0;    top: -2rem; }
    .idb-hero__star--md { font-size: 4rem; right: 5rem; top: 1.5rem; }
    .idb-hero__star--sm { font-size: 2rem; right: 1rem; top: 4.5rem; }

    .idb-stat {
        background: #fff;
        border: 1px solid #dedee5;
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        height: 100%;
    }

    .idb-stat__icon {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }

    .idb-stat__icon--students { background: rgba(133,91,251,0.16); color: #7132f5; }
    .idb-stat__icon--courses  { background: rgba(20,158,97,0.16); color: #149e61; }

    .idb-stat__label {
        font-size: 0.72rem;
        color: #9497a9;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 0.2rem;
    }

    .idb-stat__value {
        font-size: 1.8rem;
        font-weight: 700;
        color: #101114;
        line-height: 1;
        display: flex;
        align-items: baseline;
        gap: 0.4rem;
    }

    .idb-stat__badge {
        font-size: 0.68rem;
        font-weight: 600;
        padding: 2px 7px;
        border-radius: 20px;
        background: rgba(20,158,97,0.16);
        color: #149e61;
    }

    .idb-stat__sub {
        font-size: 0.78rem;
        font-weight: 400;
        color: #9497a9;
    }

    .idb-section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
    }

    .idb-section-header__title {
        font-weight: 700;
        font-size: 1.05rem;
        margin: 0;
        color: #101114;
    }

    .idb-section-header__link {
        font-size: 0.85rem;
        font-weight: 500;
        color: #7132f5;
        text-decoration: none;
    }

    .idb-section-header__link:hover { text-decoration: underline; }

    .idb-create-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        min-height: 220px;
        height: 100%;
        border: 2px dashed #ced4da;
        border-radius: 12px;
        background: #fafbfc;
        text-decoration: none;
        text-align: center;
        padding: 1.5rem;
        transition: border-color 0.2s, background 0.2s;
        cursor: pointer;
    }

    .idb-create-card:hover {
        border-color: #7132f5;
        background: rgba(133,91,251,0.06);
    }

    .idb-create-card__icon {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: rgba(133,91,251,0.16);
        color: #7132f5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        margin-bottom: 0.25rem;
    }

    .idb-create-card__label {
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        color: #7132f5;
    }

    .idb-create-card__sub {
        font-size: 0.78rem;
        color: #9497a9;
    }

    .idb-skeleton {
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        border: 1px solid #dedee5;
        min-height: 220px;
    }

    .idb-skeleton__thumb {
        height: 140px;
        background: linear-gradient(90deg, #f0f2f5 25%, #e4e7eb 50%, #f0f2f5 75%);
        background-size: 200% 100%;
        animation: idb-shimmer 1.4s infinite;
    }

    .idb-skeleton__body { padding: 0.875rem 1rem; }

    .idb-skeleton__line {
        height: 12px;
        border-radius: 6px;
        background: linear-gradient(90deg, #f0f2f5 25%, #e4e7eb 50%, #f0f2f5 75%);
        background-size: 200% 100%;
        animation: idb-shimmer 1.4s infinite;
        margin-bottom: 0.5rem;
    }

    .idb-skeleton__line--short { width: 40%; }

    @@keyframes idb-shimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }
</style>

<div>

    @* ── Hero Banner ── *@
    @* ── Search Bar ── *@
    <div class="input-group mb-3" style="max-width: 420px;">
        <span class="input-group-text bg-white border-end-0">
            <i class="fa fa-search text-muted"></i>
        </span>
        <input type="text"
               class="form-control border-start-0 ps-0"
               placeholder="Search by title or course ID…"
               @bind="SearchText"
               @bind:event="oninput" />
        @if (!string.IsNullOrEmpty(SearchText))
        {
            <button class="btn btn-outline-secondary border-start-0"
                    type="button"
                    @onclick="() => SearchText = string.Empty">
                <i class="fa fa-times"></i>
            </button>
        }
    </div>
    
    <div class="idb-hero">
        <div class="idb-hero__content">
            <h2 class="idb-hero__title">Welcome back, @(CurrentUser.Name ?? CurrentUser.UserName ?? "Instructor").</h2>
            <p class="idb-hero__subtitle">Manage your courses and track student progress.</p>
        </div>
        <div class="idb-hero__deco">
            <i class="fa fa-star idb-hero__star idb-hero__star--lg"></i>
            <i class="fa fa-star idb-hero__star idb-hero__star--md"></i>
            <i class="fa fa-star idb-hero__star idb-hero__star--sm"></i>
        </div>
    </div>
    
    @* ── Summary Stats ── *@
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-6">
            <div class="idb-stat">
                <div class="idb-stat__icon idb-stat__icon--students">
                    <i class="fa fa-users"></i>
                </div>
                <div>
                    <div class="idb-stat__label">Total Students</div>
                    <div class="idb-stat__value">
                        @if (_isLoadingStats)
                        {
                        <span class="placeholder col-5 rounded"></span>
                        }
                        else
                        {
                        @_totalStudents.ToString("N0")
                        <span class="idb-stat__badge">+12%</span>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="idb-stat">
                <div class="idb-stat__icon idb-stat__icon--courses">
                    <i class="fa fa-book-open"></i>
                </div>
                <div>
                    <div class="idb-stat__label">Total Courses</div>
                    <div class="idb-stat__value">
                        @if (_isLoadingStats)
                        {
                        <span class="placeholder col-3 rounded"></span>
                        }
                        else
                        {
                        @_totalCourses
                        <span class="idb-stat__sub">Active</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── My Courses ── *@
    <div class="idb-section-header">
        <h5 class="idb-section-header__title">My Courses</h5>
        <a href="/instructor/dashboard" class="idb-section-header__link">
            View All <i class="fa fa-arrow-right ms-1"></i>
        </a>
    </div>

    <div class="row g-3">

        @* Create New Course Card *@
        <div class="col-12 col-md-6 col-xl-4">
            <div class="idb-create-card" @onclick="OpenCreateCourseModal" role="button">
                <div class="idb-create-card__icon">
                    <i class="fa fa-plus"></i>
                </div>
                <div class="idb-create-card__label">Create New Course</div>
                <div class="idb-create-card__sub">Start designing your next digital experience</div>
            </div>
        </div>

        @if (_isLoadingCourses)
        {
        @for (var i = 0; i < 5; i++)
        {
        <div class="col-12 col-md-6 col-xl-4">
            <div class="idb-skeleton">
                <div class="idb-skeleton__thumb"></div>
                <div class="idb-skeleton__body">
                    <div class="idb-skeleton__line"></div>
                    <div class="idb-skeleton__line idb-skeleton__line--short"></div>
                </div>
            </div>
        </div>
        }
        }
        else
        {
        @foreach (var course in _courses)
        {
        <div class="col-12 col-md-6 col-xl-4">
            <InstructorCourseCard Course="course" />
        </div>
        }
        }

    </div>

</div>