@using saasLMS.CourseCatalogService.Courses

<style>
    .icc-card {
        border: 1px solid #dedee5;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        height: 100%;
        transition: box-shadow 0.2s, transform 0.2s;
        cursor: pointer;
    }

    .icc-card:hover {
        box-shadow: 0 6px 20px rgba(0,0,0,0.09);
        transform: translateY(-2px);
    }

    .icc-card__thumbnail {
        position: relative;
        height: 150px;
        background: linear-gradient(135deg, #0f2744 0%, #1a3a5c 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .icc-card__thumbnail-icon {
        color: rgba(255,255,255,0.15);
        font-size: 3.5rem;
    }

    .icc-card__status {
        position: absolute;
        top: 10px;
        left: 10px;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        padding: 3px 9px;
        border-radius: 5px;
    }

    .icc-card__status--published { background: #149e61; color: #fff; }
    .icc-card__status--draft     { background: #fbbc05; color: #fff; }
    .icc-card__status--hidden    { background: #686b82; color: #fff; }

    .icc-card__body {
        padding: 0.9rem 1rem;
    }

    .icc-card__title {
        font-weight: 600;
        font-size: 0.88rem;
        color: #101114;
        margin-bottom: 0.4rem;
        line-height: 1.45;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .icc-card__meta {
        font-size: 0.78rem;
        color: #8a93a2;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }
</style>

<div class="icc-card" @onclick="NavigateToCourse">
    <div class="icc-card__thumbnail">
        <i class="fa fa-desktop icc-card__thumbnail-icon"></i>
        <span class="icc-card__status icc-card__status--@_statusCssClass">
            @_statusLabel
        </span>
    </div>
    <div class="icc-card__body">
        <div class="icc-card__title">@Course.Title</div>
    </div>
</div>