<div class="route-loading" role="status" aria-live="polite">
    <div class="route-loading__card">
        <div class="route-loading__spinner spinner-border text-primary" role="status">
            <span class="visually-hidden">@Title</span>
        </div>
        <div class="route-loading__copy">
            <div class="route-loading__title">@Title</div>
            <div class="route-loading__text">@Message</div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Title { get; set; } = "Authorizing session";

    [Parameter]
    public string Message { get; set; } = "Checking access, tenant context, and permissions.";
}
