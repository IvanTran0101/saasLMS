<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>saasLMS</title>
    <base href="/" />

    <link href="global.css" rel="stylesheet"/>
    <link href="app-shell.css" rel="stylesheet"/>
    <link href="main.css" rel="stylesheet"/>

    <HeadOutlet @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />
</head>

<body class="abp-application-layout bg-light">
    <div id="ApplicationContainer">
        <div id="app-shell" class="app-shell" aria-live="polite">
            <div class="app-shell__panel">
                <div class="app-shell__brand">
                    <div class="app-shell__brand-mark">S</div>
                    <div class="app-shell__brand-copy">
                        <div class="app-shell__eyebrow">saasLMS</div>
                        <h1 class="app-shell__title">Loading workspace</h1>
                        <p class="app-shell__subtitle">Preparing courses, identity, and dashboard data.</p>
                    </div>
                </div>

                <div class="app-shell__progress" role="status" aria-label="Application is loading">
                    <div class="app-shell__progress-bar"></div>
                </div>

                <div class="app-shell__layout">
                    <div class="app-shell__sidebar">
                        <span class="app-shell__shimmer app-shell__shimmer--block app-shell__shimmer--logo"></span>
                        <span class="app-shell__shimmer app-shell__shimmer--line"></span>
                        <span class="app-shell__shimmer app-shell__shimmer--line app-shell__shimmer--line-short"></span>
                        <span class="app-shell__shimmer app-shell__shimmer--line"></span>
                        <span class="app-shell__shimmer app-shell__shimmer--line app-shell__shimmer--line-medium"></span>
                    </div>

                    <div class="app-shell__content">
                        <div class="app-shell__topbar">
                            <span class="app-shell__shimmer app-shell__shimmer--line app-shell__shimmer--headline"></span>
                            <span class="app-shell__shimmer app-shell__shimmer--pill"></span>
                        </div>

                        <div class="app-shell__cards">
                            <div class="app-shell__card">
                                <span class="app-shell__shimmer app-shell__shimmer--line app-shell__shimmer--card-title"></span>
                                <span class="app-shell__shimmer app-shell__shimmer--line"></span>
                                <span class="app-shell__shimmer app-shell__shimmer--line app-shell__shimmer--line-short"></span>
                            </div>
                            <div class="app-shell__card">
                                <span class="app-shell__shimmer app-shell__shimmer--line app-shell__shimmer--card-title"></span>
                                <span class="app-shell__shimmer app-shell__shimmer--line"></span>
                                <span class="app-shell__shimmer app-shell__shimmer--line app-shell__shimmer--line-medium"></span>
                            </div>
                            <div class="app-shell__card">
                                <span class="app-shell__shimmer app-shell__shimmer--line app-shell__shimmer--card-title"></span>
                                <span class="app-shell__shimmer app-shell__shimmer--line"></span>
                                <span class="app-shell__shimmer app-shell__shimmer--line app-shell__shimmer--line-short"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <Routes @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)"/>
    </div>

    <!-- Hosted interactive WASM boots from `_framework/blazor.web.js` in published output. -->
    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script src="/_content/Volo.Abp.Account.Pro.Public.Blazor.Shared/IdleTracker.js"></script>
    <script src="global.js"></script>
    <script>
        Blazor.start()
            .then(function () {
                document.body.classList.add('app-ready');
                var shell = document.getElementById('app-shell');
                if (shell) {
                    shell.setAttribute('aria-hidden', 'true');
                    window.setTimeout(function () {
                        shell.remove();
                    }, 300);
                }
            })
            .catch(function (error) {
                document.body.classList.add('app-boot-failed');
                throw error;
            });

        window.downloadFileFromBytes = function (fileName, base64Data, mimeType) {
            var bytes = Uint8Array.from(atob(base64Data), function(c) { return c.charCodeAt(0); });
            var blob = new Blob([bytes], { type: mimeType || 'application/octet-stream' });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = fileName;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        };
    </script>

</body>
</html>
