<Project Sdk="Microsoft.NET.Sdk.Web">

    <Import Project="..\..\..\..\common.props" />

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <RootNamespace>saasLMS.CourseCatalogService</RootNamespace>
        <DefaultItemExcludes>$(DefaultItemExcludes);bin\**;obj\**</DefaultItemExcludes>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.EntityFrameworkCore.Tools" Version="10.0.2">
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
        </PackageReference>
        <PackageReference Include="Volo.Abp.Http.Client.IdentityModel.Web" Version="10.1.1" />
    </ItemGroup>

    <ItemGroup>        
        <ProjectReference Include="..\..\..\..\shared\saasLMS.Shared.Hosting.Microservices\saasLMS.Shared.Hosting.Microservices.csproj" />
        <ProjectReference Include="..\saasLMS.CourseCatalogService.Application\saasLMS.CourseCatalogService.Application.csproj" />
        <ProjectReference Include="..\saasLMS.CourseCatalogService.EntityFrameworkCore\saasLMS.CourseCatalogService.EntityFrameworkCore.csproj" />
        <ProjectReference Include="..\saasLMS.CourseCatalogService.HttpApi\saasLMS.CourseCatalogService.HttpApi.csproj" />
        <ProjectReference Include="..\..\..\enrollment\src\saasLMS.EnrollmentService.Application.Contracts\saasLMS.EnrollmentService.Application.Contracts.csproj" />
    </ItemGroup>

    <ItemGroup>
        <Compile Remove="Logs\**" />
        <Content Remove="Logs\**" />
        <EmbeddedResource Remove="Logs\**" />
        <None Remove="Logs\**" />
    </ItemGroup>

    <ItemGroup>
        <Content Remove="bin\**;obj\**" />
        <None Remove="bin\**;obj\**" />
    </ItemGroup>

</Project>
