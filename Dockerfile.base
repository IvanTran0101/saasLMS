COPY "shared/saasLMS.Shared.Hosting.Gateways/saasLMS.Shared.Hosting.Gateways.csproj" "shared/saasLMS.Shared.Hosting.Gateways/saasLMS.Shared.Hosting.Gateways.csproj"
COPY "shared/saasLMS.Shared.Hosting.Microservices/saasLMS.Shared.Hosting.Microservices.csproj" "shared/saasLMS.Shared.Hosting.Microservices/saasLMS.Shared.Hosting.Microservices.csproj"
COPY "shared/saasLMS.Shared.Hosting/saasLMS.Shared.Hosting.csproj" "shared/saasLMS.Shared.Hosting/saasLMS.Shared.Hosting.csproj"
COPY "shared/saasLMS.Shared.Localization/saasLMS.Shared.Localization.csproj" "shared/saasLMS.Shared.Localization/saasLMS.Shared.Localization.csproj"

# Warm the NuGet cache for the entrypoint projects we build/publish into production images.
# This is intentionally independent from PROJECT_PATH so CI can reuse this layer across services.
RUN --mount=type=cache,target=/root/.nuget/packages \
    --mount=type=cache,target=/root/.local/share/NuGet/v3-cache \
    if [ "$WARM_RESTORE" = "1" ]; then \
      dotnet restore "apps/auth-server/src/saasLMS.AuthServer/saasLMS.AuthServer.csproj" --nologo \
      && dotnet restore "apps/blazor/src/saasLMS.Blazor/saasLMS.Blazor.csproj" --nologo \
      && dotnet restore "gateways/web-public/src/saasLMS.PublicWebGateway/saasLMS.PublicWebGateway.csproj" --nologo \
      && dotnet restore "gateways/web/src/saasLMS.WebGateway/saasLMS.WebGateway.csproj" --nologo \
      && dotnet restore "services/administration/src/saasLMS.AdministrationService.HttpApi.Host/saasLMS.AdministrationService.HttpApi.Host.csproj" --nologo \
      && dotnet restore "services/assessment/src/saasLMS.AssessmentService.HttpApi.Host/saasLMS.AssessmentService.HttpApi.Host.csproj" --nologo \
      && dotnet restore "services/courseCatalog/src/saasLMS.CourseCatalogService.HttpApi.Host/saasLMS.CourseCatalogService.HttpApi.Host.csproj" --nologo \
      && dotnet restore "services/enrollment/src/saasLMS.EnrollmentService.HttpApi.Host/saasLMS.EnrollmentService.HttpApi.Host.csproj" --nologo \
      && dotnet restore "services/identity/src/saasLMS.IdentityService.HttpApi.Host/saasLMS.IdentityService.HttpApi.Host.csproj" --nologo \
      && dotnet restore "services/learningProgress/src/saasLMS.LearningProgressService.HttpApi.Host/saasLMS.LearningProgressService.HttpApi.Host.csproj" --nologo \
      && dotnet restore "services/notification/src/saasLMS.NotificationService.HttpApi.Host/saasLMS.NotificationService.HttpApi.Host.csproj" --nologo \
      && dotnet restore "services/product/src/saasLMS.ProductService.HttpApi.Host/saasLMS.ProductService.HttpApi.Host.csproj" --nologo \
      && dotnet restore "services/reporting/src/saasLMS.ReportingService.HttpApi.Host/saasLMS.ReportingService.HttpApi.Host.csproj" --nologo \
      && dotnet restore "services/saas/src/saasLMS.SaasService.HttpApi.Host/saasLMS.SaasService.HttpApi.Host.csproj" --nologo \
      && dotnet restore "shared/saasLMS.DbMigrator/saasLMS.DbMigrator.csproj" --nologo; \
    fi

# Restore the selected project (single restore per build).
RUN --mount=type=cache,target=/root/.nuget/packages \
    --mount=type=cache,target=/root/.local/share/NuGet/v3-cache \
    [ -n "$PROJECT_PATH" ] && dotnet restore "$PROJECT_PATH" --nologo \
    || (echo "PROJECT_PATH is required." && exit 1)

FROM ${DOTNET_SDK_IMAGE} AS publish
WORKDIR /src

ARG PROJECT_PATH=""
ARG CONFIGURATION=Release

ENV DOTNET_CLI_TELEMETRY_OPTOUT=1 \
    DOTNET_SKIP_FIRST_TIME_EXPERIENCE=1 \
    NUGET_XMLDOC_MODE=skip \
    NUGET_PACKAGES=/root/.nuget/packages

# Bring restored assets (obj/project.assets.json) from the restore stage, then overlay full source.
# NOTE: host-side **/obj is typically .dockerignored, so restored assets remain intact.
COPY --from=restore /src/ /src/
COPY . .
RUN [ -n "$PROJECT_PATH" ] || (echo "PROJECT_PATH is required." && exit 1)

RUN --mount=type=cache,target=/root/.nuget/packages \
    --mount=type=cache,target=/root/.local/share/NuGet/v3-cache \
    dotnet publish "$PROJECT_PATH" -c "$CONFIGURATION" -o /app/publish --no-restore \
  -p:UseAppHost=false \
  -p:ContinuousIntegrationBuild=true

FROM ${DOTNET_RUNTIME_IMAGE} AS runtime
WORKDIR /app

ARG ENTRY_DLL=""

ENV ASPNETCORE_URLS=http://+:80 \
    ENTRY_DLL=${ENTRY_DLL}
EXPOSE 80

COPY --from=publish /app/publish/ ./
COPY "etc/docker/entrypoints/run-with-secrets.sh" "/app/run-with-secrets.sh"
RUN chmod +x "/app/run-with-secrets.sh"

ENTRYPOINT ["/app/run-with-secrets.sh"]
# JSON-array CMD can't expand env vars. We use a shell wrapper so ENTRY_DLL can be passed via build-arg.
CMD ["sh", "-c", "test -n \"$ENTRY_DLL\" || { echo 'ENTRY_DLL is required.'; exit 1; }; exec dotnet \"$ENTRY_DLL\""]
    
