## syntax=docker/dockerfile:1.7
##
# Common multi-stage Dockerfile for building ANY service/app in this solution.
#
# Usage examples:
#   docker build -f Dockerfile.base \
#     --build-arg PROJECT_PATH=services/identity/src/saasLMS.IdentityService.HttpApi.Host/saasLMS.IdentityService.HttpApi.Host.csproj \
#     --build-arg ENTRY_DLL=saasLMS.IdentityService.HttpApi.Host.dll \
#     -t mycompanyname/saaslms-service-identity:latest .
#
# Notes:
# - Stage 1 (restore): copies only *.csproj (+ NuGet.Config/common.props) for cacheable restore.
# - Stage 2 (publish): copies full source and publishes the selected PROJECT_PATH.
# - Stage 3 (runtime): runs via run-with-secrets.sh to map Docker Swarm secrets -> env vars.
##

ARG DOTNET_SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:10.0
ARG DOTNET_RUNTIME_IMAGE=mcr.microsoft.com/dotnet/aspnet:10.0

FROM ${DOTNET_SDK_IMAGE} AS restore
WORKDIR /src

ARG PROJECT_PATH=""
ARG CONFIGURATION=Release
ARG WARM_RESTORE=0

ENV DOTNET_CLI_TELEMETRY_OPTOUT=1 \
    DOTNET_SKIP_FIRST_TIME_EXPERIENCE=1 \
    NUGET_XMLDOC_MODE=skip \
    NUGET_PACKAGES=/root/.nuget/packages

COPY "saasLMS.sln" "NuGet.Config" "common.props" ./

# Copy only project files for a fast, cacheable restore layer.
# (We intentionally avoid copying full source here.)
COPY "apps/auth-server/src/saasLMS.AuthServer/saasLMS.AuthServer.csproj" "apps/auth-server/src/saasLMS.AuthServer/saasLMS.AuthServer.csproj"
